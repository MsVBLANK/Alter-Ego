{
    "extends": "@tsconfig/node24/tsconfig.json",
    "compilerOptions": {
        "rootDir": "./",
        "noEmit": true,
        "skipLibCheck": false,
        // JS support
        "allowJs": true,
        "checkJs": true,
        // Interop
        "resolveJsonModule": true,
        "verbatimModuleSyntax": true,
        "rewriteRelativeImportExtensions": true,
        "erasableSyntaxOnly": true,
        // Type checking
        "strict": false
    },
    "include": [
        "**/*"
    ],
    "exclude": [
        "coverage"
    ]
}
